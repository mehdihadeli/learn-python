      "source": [
        "## Type Conversion\n",
        "\n",
        "Python lets you convert between types explicitly."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "age = \"25\"\n",
        "age_number = int(age)\n",
        "\n",
        "price = 19\n",
        "price_float = float(price)\n",
        "\n",
        "number = 123\n",
        "number_text = str(number)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Be careful: conversion can fail."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "int(\"hello\")\n",
        "# ValueError"
      ]
    }
